{
    "version": "0.10.10",
    "description": "An extremely fast Python package installer and resolver, written in Rust.",
    "homepage": "https://docs.astral.sh/uv/",
    "license": "Apache-2.0|MIT",
    "architecture": {
        "64bit": {
            "url": "https://mirrors.ustc.edu.cn/github-release/astral-sh/uv/0.10.10/uv-x86_64-pc-windows-msvc.zip",
            "hash": "d31a30f1dfb96e630a08d5a9b3f3f551254b7ed6e9b7e495f46a4232661c7252"
        },
        "32bit": {
            "url": "https://mirrors.ustc.edu.cn/github-release/astral-sh/uv/0.10.10/uv-i686-pc-windows-msvc.zip",
            "hash": "980d7ea368cc4883f572bb85c285a647eddfc23539064d2bfaf8fbfefcc2112b"
        },
        "arm64": {
            "url": "https://mirrors.ustc.edu.cn/github-release/astral-sh/uv/0.10.10/uv-aarch64-pc-windows-msvc.zip",
            "hash": "2c6fe113f14574bc27f085751c68d3485589fcc3c3c64ed85dd1eecc2f87cffc"
        }
    },
    "bin": [
        "uv.exe",
        "uvx.exe"
    ],
    "persist": "data",
    "env_set": {
        "PYTHONUTF8": "1",
        "UV_PYTHON_INSTALL_MIRROR": "https://mirror.nju.edu.cn/github-release/astral-sh/python-build-standalone/",
        "UV_DEFAULT_INDEX": "https://mirrors.ustc.edu.cn/pypi/simple",
        "UV_CACHE_DIR": "$dir\\data\\cache",
        "UV_PYTHON_INSTALL_DIR": "$dir\\data\\python",
        "UV_PYTHON_BIN_DIR": "$dir\\data\\bin",
        "UV_TOOL_DIR": "$dir\\data\\tool",
        "UV_TOOL_BIN_DIR": "$dir\\data\\bin"
    },
    "env_add_path": "data\\bin",
    "checkver": {
        "github": "https://github.com/astral-sh/uv"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://mirrors.ustc.edu.cn/github-release/astral-sh/uv/$version/uv-x86_64-pc-windows-msvc.zip"
            },
            "32bit": {
                "url": "https://mirrors.ustc.edu.cn/github-release/astral-sh/uv/$version/uv-i686-pc-windows-msvc.zip"
            },
            "arm64": {
                "url": "https://mirrors.ustc.edu.cn/github-release/astral-sh/uv/$version/uv-aarch64-pc-windows-msvc.zip"
            }
        },
        "hash": {
            "url": "$url.sha256"
        }
    }
}
